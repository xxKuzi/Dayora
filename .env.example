# Gemini API Key (Server-side)
# Get your API key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key

# Resend API Key (Server-side)
# Get your API key from: https://resend.com/
RESEND_API_KEY=your_resend_api_key
# Resend From Email (e.g., "Dayora App <no-reply@yourdomain.com>"). 
# Defaults to "Dayora App <onboarding@resend.dev>". 
# Note: onboarding@resend.dev restricts recipient delivery to your registered Resend developer account.
# To send to any user, verify a custom domain in Resend and set its sender email here.
# RESEND_FROM_EMAIL=Dayora App <no-reply@yourdomain.com>
RESEND_FROM_EMAIL=Dayora App <no-reply@yourdomain.com>

# Firebase Configuration (Client-side, prefixed with NEXT_PUBLIC_ for Next.js)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_storage_bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
